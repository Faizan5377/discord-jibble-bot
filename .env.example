# Discord
DISCORD_BOT_TOKEN=your_discord_bot_token
DISCORD_CHANNEL_ID=  # optional: restrict bot to specific channel(s), comma-separated

# Jibble API (OAuth2 Client Credentials)
JIBBLE_CLIENT_ID=your_jibble_client_id
JIBBLE_CLIENT_SECRET=your_jibble_client_secret

# Jibble API URLs (defaults are set in config.ts, only override if needed)
JIBBLE_IDENTITY_URL=https://identity.prod.jibble.io
JIBBLE_WORKSPACE_URL=https://workspace.prod.jibble.io
JIBBLE_TIMETRACKING_URL=https://time-tracking.prod.jibble.io
